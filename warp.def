Bootstrap: docker
From: mcr.microsoft.com/dotnet/sdk:10.0

# Expects environment.yml (the corrected conda-forge one, name: warp_build)
# to be in the same directory when you run the build.
%files
    environment.yml /opt/environment.yml

%post
    set -eu
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    # make is required by cmake's "Unix Makefiles" generator; it is not in the
    # base image or the conda env.
    apt-get install -y --no-install-recommends wget git ca-certificates bzip2 make
    rm -rf /var/lib/apt/lists/*

    # Miniforge installs with conda-forge as the default channel
    wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh -O /tmp/miniforge.sh
    bash /tmp/miniforge.sh -b -p /opt/conda
    rm /tmp/miniforge.sh

    . /opt/conda/etc/profile.d/conda.sh
    conda config --set channel_priority strict
    # No GPU is present at build time, so conda can't detect the __cuda virtual
    # package and refuses the CUDA pytorch build. Override it to the cluster's
    # CUDA version so the correct GPU build is selected; the real GPU is present
    # at runtime via --nv.
    export CONDA_OVERRIDE_CUDA="12.4"
    conda env create -f /opt/environment.yml
    conda clean -ya

# Kept dash-safe: do NOT run `conda activate` here. Singularity sources this
# with /bin/sh (dash), which cannot parse conda's bash compiler-activation
# scripts. Activate the env under bash at runtime instead (see usage below).
%environment
    export PATH=/opt/conda/bin:$PATH
    export DOTNET_CLI_TELEMETRY_OPTOUT=1

%runscript
    exec "$@"
